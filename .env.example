# ── OPÇÃO 1 (recomendada para Vercel) ──────────────────────────
# Connection string de um Postgres serverless, como Neon ou Supabase.
# Se DATABASE_URL estiver definida, ela tem prioridade sobre as variáveis abaixo.
# Exemplo (Neon): postgresql://usuario:senha@ep-xxxx.neon.tech/sistema_servicos?sslmode=require
DATABASE_URL=

# ── OPÇÃO 2 (uso local com Postgres tradicional) ───────────────
PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sistema_servicos
